generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../../../data/server-probe.sqlite"
}

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  username       String?
  action         String
  targetType     String
  targetId       String?
  targetName     String?
  requestPayload String?
  result         String
  errorMessage   String?
  ip             String?
  userAgent      String?
  traceId        String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([result])
  @@index([targetType, targetId])
  @@index([userId])
}
